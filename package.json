{
  "name": "bolo",
  "version": "0.0.1",
  "description": "Bolo, a game of tank warfare, rewritten for modern browsers.",
  "homepage": "https://github.com/davidangel/bolo",
  "repository": {
    "type": "git",
    "url": "https://github.com/davidangel/bolo.git"
  },
  "author": {
    "name": "Stéphan Kochen",
    "email": "stephan@kochen.nl",
    "url": "http://stephan.kochen.nl/"
  },
  "scripts": {
    "build:css": "npx tailwindcss -i ./css/bolo.css -o ./css/compiled.css --minify",
    "build:js": "node ./scripts/build-js.js",
    "build": "npm run build:css && npm run build:js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "server": "node ./bin/bolo-server config.json",
    "generate-map-previews": "node ./scripts/generate-map-previews.js"
  },
  "engines": {
    "node": ">=14"
  },
  "dependencies": {
    "browserify": "^17.0.0",
    "coffeescript": "^2.7.0",
    "connect": "^3.7.0",
    "faye-websocket": "^0.11.0",
    "irc": "^0.5.2",
    "morgan": "^1.10.0",
    "serve-static": "^1.15.0",
    "sharp": "^0.34.5",
    "ts-node": "^10.9.2",
    "villain": "file:vendor/villain"
  },
  "bin": {
    "bolo-server": "./bin/bolo-server"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "bn.js": "5.2.3"
  },
  "devDependencies": {
    "@types/connect": "^3.4.38",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "jest-util": "^29.7.0",
    "pngjs": "^7.0.0",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.1",
    "typescript": "^5.9.3"
  }
}

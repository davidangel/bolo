#!/usr/bin/env node

const path = require('path');
const fs = require('fs');

const tsconfigPath = path.join(__dirname, '../tsconfig.json');
const fallbackCompilerOptions = {
	module: 'CommonJS',
	moduleResolution: 'node',
	esModuleInterop: true,
	target: 'ES2020',
	resolveJsonModule: true,
	skipLibCheck: true
};

require('ts-node').register(
	fs.existsSync(tsconfigPath)
		? { project: tsconfigPath, transpileOnly: true }
		: { transpileOnly: true, skipProject: true, compilerOptions: fallbackCompilerOptions }
);
require('../src/server/command').run();
